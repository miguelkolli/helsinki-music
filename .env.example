# ── Required ─────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── Database (set this to your Railway volume mount path) ─────────
DB_PATH=/app/data/mgevents.db

# ── Crawl behaviour ───────────────────────────────────────────────
# Run a crawl immediately when the server starts (true/false)
CRAWL_ON_START=true
# How many days ahead to fetch events
CRAWL_DAYS=90

# ── API Keys (optional — crawlers skip silently if not set) ───────
# Get a free key at: https://developer.ticketmaster.com
TICKETMASTER_API_KEY=

# Apply at: https://www.songkick.com/developer
SONGKICK_API_KEY=
